<Window x:Class="RoguelikeGame.Views.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoguelikeGame.Views"
        mc:Ignorable="d"
       Title="Roguelike" Height="400" Width="600">

    <Grid Background="Black">

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="ROGUELIKE GAME"
                       Foreground="White"
                       FontSize="32"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 30"/>

            <Button Content="Начать игру"
                    Width="200"
                    Height="50"
                    Click="StartGame_Click"/>

        </StackPanel>

    </Grid>
</Window>
