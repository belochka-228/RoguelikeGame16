<Window x:Class="RoguelikeGame.Views.GameOver"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoguelikeGame.Views"
        mc:Ignorable="d"
        Title="Game Over" Height="450" Width="800">

    <Grid Background="#3b2a47">

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Вы проиграли:(" Foreground="White" FontSize="40" HorizontalAlignment="Center" Margin="0 0 0 30"/>

            <Button Content="Начать заново" FontSize="20" Width="200" Height="50" Click="Restart_Click"/>

        </StackPanel>

    </Grid>
</Window>
