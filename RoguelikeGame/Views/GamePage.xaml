<Window x:Class="RoguelikeGame.Views.GamePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoguelikeGame.Views"
        mc:Ignorable="d"
        Title="Roguelike"
        WindowState="Maximized"
        Background="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Background="#2a2a2a">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FloorText" Grid.Column="0" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Здоровье" Foreground="White" HorizontalAlignment="Center" FontSize="14"/>
                <Grid Width="350">
                    <ProgressBar x:Name="HpBar" Height="28"/>
                    <TextBlock x:Name="HpText" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="14"/>
                </Grid>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Image Source="/Assets/UI/room.png" Stretch="Fill"/>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,20">
                <TextBlock Text="Оружие" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <Border BorderBrush="Gray" BorderThickness="2" CornerRadius="10" Background="#44000000" Padding="10">
                    <Image x:Name="WeaponImage" Width="120" Height="150"/>
                </Border>

                <TextBlock x:Name="WeaponStats" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>

                <TextBlock Text="Доспех" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,20,0,10"/>
                <Border BorderBrush="Gray" BorderThickness="2" CornerRadius="10"  Background="#44000000" Padding="10">
                    <Image x:Name="ArmorImage" Width="120" Height="150"/>
                </Border>

                <TextBlock x:Name="ArmorStats" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <ItemsControl x:Name="EnemyPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="340" Margin="10" Background="#88000000" CornerRadius="10">
                <TextBox x:Name="LogBox" Background="Transparent" Foreground="White" BorderThickness="0" IsReadOnly="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="10" FontSize="13"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
                <Button Content="Атака" Width="180" Height="50" Margin="30" FontSize="16" FontWeight="Bold" Click="Attack_Click"/>

                <Button Content="Защита" Width="180" Height="50" Margin="30" FontSize="16" FontWeight="Bold" Click="Defense_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>