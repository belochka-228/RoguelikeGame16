<Window x:Class="RoguelikeGame.Views.GamePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoguelikeGame.Views"
        mc:Ignorable="d"
       Title="Roguelike" Height="600" Width="900">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- Панель игрока -->

        <StackPanel Orientation="Horizontal" Grid.Row="0" Background="Gray">

            <TextBlock x:Name="HpText"
                       FontSize="16"
                       Margin="20"/>

            <TextBlock x:Name="WeaponText"
                       FontSize="16"
                       Margin="20"/>

            <TextBlock x:Name="ArmorText"
                       FontSize="16"
                       Margin="20"/>

            <TextBlock x:Name="FloorText"
                       FontSize="16"
                       Margin="20"/>

        </StackPanel>


        <!-- Комната -->

        <Grid Grid.Row="1">

            <Image Source="/Assets/UI/room.png"
                   Stretch="Fill"/>

            <Image x:Name="EnemyImage"
                   Width="200"
                   Height="200"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0 0 0 30">

                <Button Content="Атака"
                        Width="120"
                        Margin="10"
                        Click="Attack_Click"/>

                <Button Content="Защита"
                        Width="120"
                        Margin="10"
                        Click="Defense_Click"/>

            </StackPanel>

        </Grid>


        <!-- Лог событий -->

        <TextBox x:Name="LogBox"
                 Grid.Row="2"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

    </Grid>
</Window>